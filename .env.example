# Local development environment for the book_reader app

# Backend
# For a physical device use your dev machine's LAN IP and a trailing slash.
API_BASE_URL=http://192.168.1.100:3000/api/
# API key used for the /api/mobile/* routes in the admin panel.
# Must match the MOBILE_API_KEY value set in the admin panel's .env file.
API_KEY=
# The author this app belongs to. Used as ?authorId=... on mobile API calls.
AUTHOR_ID=
APP_ENV=development

